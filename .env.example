# Supabase self-hosted PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Port for the OTel collector to listen on (default: 4318)
OTEL_COLLECTOR_PORT=4318

# Token limits for quota percentage calculations.
# Set these to match your Claude subscription plan.
# Max 5x limits are automatically derived as 5× the Pro values.
PRO_WINDOW_TOKENS=
PRO_PERIOD_TOKENS=
